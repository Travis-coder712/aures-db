<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aures.pipeline</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/travishughes/aures-db/scripts/aures-pipeline.sh</string>
    </array>

    <!-- Run every Monday at 6:00 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/travishughes/aures-db/logs/launchd-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/travishughes/aures-db/logs/launchd-stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/travishughes/aures-db</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>

    <!-- Don't start at load, wait for scheduled time -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
